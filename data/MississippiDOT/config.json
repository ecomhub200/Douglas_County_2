{
  "state": {
    "name": "Mississippi",
    "abbreviation": "MS",
    "fips": "28",
    "dotName": "MDOT",
    "dotFullName": "Mississippi Department of Transportation",
    "dataPortalUrl": "https://gis-mdot.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 30.17,
      "latMax": 34.99,
      "lonMin": -91.66,
      "lonMax": -88.1
    },
    "dataDir": "MississippiDOT"
  },
  "columnMapping": {
    "_description": "Maps Mississippi crash data fields to internal CRASH LENS field codes",
    "_note": "Column names sourced from Mississippi data dictionary. Update as API schema is confirmed.",
    "ID": "_TBD_CRASH_ID",
    "DATE": "_TBD_CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_TBD_LATITUDE",
    "LON": "_TBD_LONGITUDE",
    "SEVERITY": "_TBD_SEVERITY",
    "JURISDICTION": "_TBD_COUNTY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD",
      "_note": "Update with Mississippi-specific severity derivation method"
    },
    "YEAR": {
      "method": "extract_year",
      "source": "_TBD_CRASH_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Mississippi road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Mississippi collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 462,
    "A": 62,
    "B": 12,
    "C": 5,
    "O": 1,
    "_source": "FHWA/HSM Standard"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "MDOT GIS Portal",
    "url": "https://gis-mdot.opendata.arcgis.com",
    "apiUrl": "https://gis-mdot.opendata.arcgis.com/datasets/crashes/FeatureServer/0",
    "fileFormat": "GeoJSON/CSV (ArcGIS)",
    "dataDictionary": "See gis-mdot.opendata.arcgis.com dataset metadata",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
