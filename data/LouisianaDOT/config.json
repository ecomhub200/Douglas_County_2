{
  "state": {
    "name": "Louisiana",
    "abbreviation": "LA",
    "fips": "22",
    "dotName": "LADOTD",
    "dotFullName": "Louisiana Department of Transportation and Development",
    "dataPortalUrl": "https://data-ladotd.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 28.93,
      "latMax": 33.02,
      "lonMin": -94.04,
      "lonMax": -88.82
    },
    "dataDir": "LouisianaDOT"
  },
  "columnMapping": {
    "_description": "Maps Louisiana crash data fields to CRASH LENS field codes",
    "_note": "NOT PUBLICLY AVAILABLE on LADOTD open data portal (roadway infrastructure only). Louisiana crash data managed by CARTS (Crash Analysis Research & Technical Support) at LSU: carts.lsu.edu. Uses Louisiana parishes (not counties). Contact CARTS or Louisiana Highway Safety Commission for access.",
    "ID": "_TBD_CRASH_ID",
    "DATE": "_TBD_CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_TBD_LATITUDE",
    "LON": "_TBD_LONGITUDE",
    "SEVERITY": "_TBD_SEVERITY",
    "JURISDICTION": "_TBD_COUNTY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD",
      "_note": "Update with Louisiana-specific severity derivation method"
    },
    "YEAR": {
      "method": "extract_year",
      "source": "_TBD_CRASH_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Louisiana road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road"
        ],
        "label": "County Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      },
      "cityOnly": {
        "include": [
          "Local Road"
        ],
        "label": "City Roads Only"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Louisiana collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 462,
    "A": 62,
    "B": 12,
    "C": 5,
    "O": 1,
    "_source": "FHWA/HSM Standard"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "LADOTD GIS Portal",
    "url": "https://data-ladotd.opendata.arcgis.com",
    "apiUrl": "_NO_PUBLIC_CRASH_ENDPOINT",
    "_apiNote": "LADOTD open data portal has roadway infrastructure only, NO crash data. ArcGIS REST at maps.dotd.la.gov/road/rest/services/ has roadway data only.",
    "fileFormat": "GeoJSON/CSV (ArcGIS - NOT available publicly)",
    "dataDictionary": "Contact CARTS at LSU: https://carts.lsu.edu/projects/gis/ or Louisiana Highway Safety Commission",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
