{
  "state": {
    "name": "Montana",
    "abbreviation": "MT",
    "fips": "30",
    "dotName": "MDT",
    "dotFullName": "Montana Department of Transportation",
    "dataPortalUrl": "https://gis-mdt.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 44.36,
      "latMax": 49.0,
      "lonMin": -116.05,
      "lonMax": -104.04
    },
    "dataDir": "MontanaDOT"
  },
  "columnMapping": {
    "_description": "Maps Montana MDT crash data fields to CRASH LENS field codes",
    "_note": "No dedicated public crash FeatureServer found. Public Crash Information Map (ArcGIS web viewer) shows 2020-2024 data but FeatureServer URL must be captured from browser dev tools. Open data portal has traffic count/route/speed data only. Severity info may not be in all download formats. See mdt.mt.gov/publications/datastats/crashdata.aspx.",
    "ID": "_TBD_CRASH_ID",
    "DATE": "_TBD_CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_TBD_LATITUDE",
    "LON": "_TBD_LONGITUDE",
    "SEVERITY": "_TBD_SEVERITY",
    "JURISDICTION": "_TBD_COUNTY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD",
      "_note": "Update with Montana-specific severity derivation method"
    },
    "YEAR": {
      "method": "extract_year",
      "source": "_TBD_CRASH_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Montana road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Montana collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 462,
    "A": 62,
    "B": 12,
    "C": 5,
    "O": 1,
    "_source": "FHWA/HSM Standard"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "MDT GIS Portal",
    "url": "https://gis-mdt.opendata.arcgis.com",
    "apiUrl": "_TBD_FROM_WEB_MAP",
    "_webMap": "https://mdt.maps.arcgis.com/apps/webappviewer/index.html?id=237b766a07074259ad7a6eec66d699b7",
    "_apiNote": "No public FeatureServer indexed. Crash data web map (2020-2024) available; use browser dev tools to capture underlying service URL. ArcGIS REST at app.mdt.mt.gov/arcgis/rest/services/ has traffic count data only.",
    "fileFormat": "GeoJSON/CSV (ArcGIS - limited public access)",
    "dataDictionary": "See mdt.mt.gov/publications/datastats/crashdata.aspx. Severity info may not be in all formats - contact MDT directly for detailed data.",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
