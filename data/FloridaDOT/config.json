{
  "state": {
    "name": "Florida",
    "abbreviation": "FL",
    "fips": "12",
    "dotName": "FDOT",
    "dotFullName": "Florida Department of Transportation",
    "dataPortalUrl": "https://gis-fdot.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 24.4,
      "latMax": 31.0,
      "lonMin": -87.63,
      "lonMax": -80.03
    },
    "dataDir": "FloridaDOT"
  },
  "columnMapping": {
    "_description": "Maps FDOT Crashes_All FeatureServer fields to CRASH LENS field codes",
    "_note": "Column names from FDOT State Safety Office Crashes_All FeatureServer/0",
    "ID": "CRASH_NUMBER",
    "XID": "XID",
    "DATE": "CRASH_DATE",
    "TIME": "CRASH_TIME",
    "LAT": "OFFICER_LATITUDE",
    "LON": "OFFICER_LONGITUDE",
    "SAFETY_LAT": "SAFETYLAT",
    "SAFETY_LON": "SAFETYLON",
    "SEVERITY": "_DERIVED",
    "JURISDICTION": "COUNTY_TXT",
    "COUNTY_CODE": "DOT_CNTY_CD",
    "DISTRICT": "DOT_GEOG_DIST_CD",
    "ROUTE": "ON_ROADWAY_NAME",
    "CROSS_STREET": "INT_ROADWAY_NAME",
    "COLLISION": "FRST_HARM_LOC_CD",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "JCT_CD",
    "INTERSECTION_TYPE": "INTCT_TYP_CD",
    "HITRUN": "_TBD_HIT_AND_RUN",
    "YEAR": "CALENDAR_YEAR",
    "DAY_OF_WEEK": "WEEKDAY_TXT",
    "ROADWAY_ID": "ROADWAYID",
    "STATE_ROAD": "STATE_ROAD_NUMBER",
    "US_ROAD": "US_ROAD_NUMBER",
    "FUNCTIONAL_CLASS": "FUNCLASS",
    "ROAD_SYSTEM": "DHSRDSYS",
    "IN_TOWN": "IN_TOWN_FLAG",
    "CASE_NUMBER": "CASE_NUMBER",
    "AGENCY_TYPE": "AGENCY_TYPE_TXT"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD_SEVERITY_FIELD",
      "_note": "Florida severity may require joining with person-level data or using crash-level severity field. Check Crashes_All FeatureServer fields for CRASH_SEV or similar."
    },
    "YEAR": {
      "method": "direct",
      "source": "CALENDAR_YEAR"
    },
    "NODE": {
      "method": "concatenate",
      "sources": ["ON_ROADWAY_NAME", "INT_ROADWAY_NAME"],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Florida road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Florida collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 462,
    "A": 62,
    "B": 12,
    "C": 5,
    "O": 1,
    "_source": "FHWA/HSM Standard"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "FDOT GIS Portal",
    "url": "https://gis-fdot.opendata.arcgis.com",
    "apiUrl": "https://gis.fdot.gov/arcgis/rest/services/Crashes_All/FeatureServer/0",
    "fileFormat": "GeoJSON/CSV (ArcGIS)",
    "dataDictionary": "FDOT State Safety Office - Signal4 data dictionary",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
