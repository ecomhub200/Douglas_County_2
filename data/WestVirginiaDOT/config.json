{
  "state": {
    "name": "West Virginia",
    "abbreviation": "WV",
    "fips": "54",
    "dotName": "WVDOT",
    "dotFullName": "West Virginia Department of Transportation",
    "dataPortalUrl": "https://data-wvdot.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 37.2,
      "latMax": 40.64,
      "lonMin": -82.64,
      "lonMax": -77.72
    },
    "dataDir": "WestVirginiaDOT"
  },
  "columnMapping": {
    "_description": "Maps West Virginia crash data fields to CRASH LENS field codes",
    "_note": "NOT PUBLICLY AVAILABLE. WVDOT open data portal has route/boundary/asset data only, no crash layers. ArcGIS REST at gis.transportation.wv.gov has no indexed crash layer. Crash reports use DOH Form 17-C. Contact WVDOT at DOTSupport@wv.gov for data access.",
    "ID": "_TBD_CRASH_ID",
    "DATE": "_TBD_CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_TBD_LATITUDE",
    "LON": "_TBD_LONGITUDE",
    "SEVERITY": "_TBD_SEVERITY",
    "JURISDICTION": "_TBD_COUNTY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD",
      "_note": "Update with West Virginia-specific severity derivation method"
    },
    "YEAR": {
      "method": "extract_year",
      "source": "_TBD_CRASH_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "West Virginia road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps West Virginia collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 883,
    "A": 94,
    "B": 21,
    "C": 11,
    "O": 1,
    "_source": "FHWA-SA-25-021 (Oct 2025) crash costs in 2024 dollars"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "WVDOT GIS Portal",
    "url": "https://data-wvdot.opendata.arcgis.com",
    "apiUrl": "_NO_PUBLIC_CRASH_ENDPOINT",
    "_apiNote": "No public crash FeatureServer found. Check gis.transportation.wv.gov/arcgis/rest/services/ for internal layers.",
    "_performancePortal": "https://performanceconnect-wvdot.hub.arcgis.com/pages/download-data",
    "fileFormat": "GeoJSON/CSV (ArcGIS - NOT available publicly)",
    "dataDictionary": "DOH Form 17-C crash report. See transportation.wv.gov/highways/traffic/Pages/Traffic-Accident-Data.aspx. Contact DOTSupport@wv.gov.",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
