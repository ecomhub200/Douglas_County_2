{
  "state": {
    "name": "Pennsylvania",
    "abbreviation": "PA",
    "fips": "42",
    "dotName": "PennDOT",
    "dotFullName": "Pennsylvania Department of Transportation",
    "dataPortalUrl": "https://crashinfo.penndot.pa.gov",
    "coordinateBounds": {
      "latMin": 39.72,
      "latMax": 42.27,
      "lonMin": -80.52,
      "lonMax": -74.69
    },
    "dataDir": "PennsylvaniaDOT"
  },
  "columnMapping": {
    "_description": "Maps PennDOT CRASH table fields to CRASH LENS field codes",
    "_note": "Column names from PennDOT Open Data Portal Data Dictionary (2025). Primary key is CRN. CRASH_DATE is stored as text yyyymmdd.",
    "ID": "CRN",
    "DATE": "CRASH_DATE",
    "TIME": "HOUR_OF_DAY",
    "LAT": "DEC_LAT",
    "LON": "DEC_LONG",
    "SEVERITY": "MAX_SEVERITY_LEVEL",
    "JURISDICTION": "COUNTY",
    "DISTRICT": "DISTRICT",
    "MUNICIPALITY": "MUNICIPALITY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "COLLISION_TYPE",
    "WEATHER": "WEATHER",
    "LIGHT": "ILLUMINATION",
    "SURFACE_CONDITION": "ROAD_CONDITION",
    "JUNCTION": "INTERSECT_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN",
    "YEAR": "CRASH_YEAR",
    "MONTH": "CRASH_MONTH",
    "DAY_OF_WEEK": "DAY_OF_WEEK",
    "FATAL_COUNT": "FATAL_COUNT",
    "MAJOR_INJURY_COUNT": "MAJ_INJ_COUNT",
    "MODERATE_INJURY_COUNT": "MOD_INJ_COUNT",
    "MINOR_INJURY_COUNT": "MIN_INJ_COUNT",
    "TOTAL_INJURY_COUNT": "TOT_INJ_COUNT",
    "UNKNOWN_INJURY_COUNT": "UNK_INJ_COUNT",
    "AGGRESSIVE_DRIVING": "AGGRESSIVE_DRIVING"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_coded",
      "source": "MAX_SEVERITY_LEVEL",
      "_note": "PennDOT MAX_SEVERITY_LEVEL maps to KABCO. Also available: FATAL_COUNT for fatal flag, INJ_SEVERITY in PERSON table for individual KABCO."
    },
    "YEAR": {
      "method": "extract_from_text",
      "source": "CRASH_DATE",
      "_note": "CRASH_DATE is stored as text in yyyymmdd format, extract first 4 chars for year"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Pennsylvania road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Pennsylvania collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 462,
    "A": 62,
    "B": 12,
    "C": 5,
    "O": 1,
    "_source": "FHWA/HSM Standard"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "PennDOT GIS Portal",
    "url": "https://crashinfo.penndot.pa.gov",
    "apiUrl": "https://gis.penndot.pa.gov/arcgis/rest/services/CrashData/FeatureServer/0",
    "fileFormat": "GeoJSON/CSV (ArcGIS)",
    "dataDictionary": "https://gis.penndot.pa.gov/gishub/crashZip/Crash_Data_Dictionary_2025.pdf",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
