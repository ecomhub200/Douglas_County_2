{
  "state": {
    "name": "Oklahoma",
    "abbreviation": "OK",
    "fips": "40",
    "dotName": "OKDOT",
    "dotFullName": "Oklahoma Department of Transportation",
    "dataPortalUrl": "https://gis-okdot.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 33.62,
      "latMax": 37.0,
      "lonMin": -103.0,
      "lonMax": -94.43
    },
    "dataDir": "OklahomaDOT"
  },
  "columnMapping": {
    "_description": "Maps Oklahoma crash data fields to CRASH LENS field codes",
    "_note": "Oklahoma uses Numetric for crash data querying (not public ArcGIS FeatureServer). Open data portal has roadway/bridge data only. GRIP (intranet-only) has crash statistics. Contact OKDOT for direct data access.",
    "ID": "_TBD_CRASH_ID",
    "DATE": "_TBD_CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_TBD_LATITUDE",
    "LON": "_TBD_LONGITUDE",
    "SEVERITY": "_TBD_SEVERITY",
    "JURISDICTION": "_TBD_COUNTY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD",
      "_note": "Update with Oklahoma-specific severity derivation method"
    },
    "YEAR": {
      "method": "extract_year",
      "source": "_TBD_CRASH_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Oklahoma road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Oklahoma collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 883,
    "A": 94,
    "B": 21,
    "C": 11,
    "O": 1,
    "_source": "FHWA-SA-25-021 (Oct 2025) crash costs in 2024 dollars"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "OKDOT GIS Portal",
    "url": "https://gis-okdot.opendata.arcgis.com",
    "apiUrl": "_NO_PUBLIC_CRASH_FEATURESERVER",
    "_numetricCrashQuery": "https://support.numetric.com/en/articles/6150044-odot-crash-query-overview",
    "_numetricFilterGuide": "https://support.numetric.com/en/articles/9375621-oklahoma-dot-crash-query-filter-guide",
    "_spotlightHub": "https://spotlight-okdot.hub.arcgis.com",
    "fileFormat": "GeoJSON/CSV (Numetric - not public ArcGIS)",
    "dataDictionary": "OKDOT Numetric Crash Query. Portal has roadway data only. GRIP is intranet-only.",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
