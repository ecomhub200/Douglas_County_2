{
  "state": {
    "name": "Utah",
    "abbreviation": "UT",
    "fips": "49",
    "dotName": "UDOT",
    "dotFullName": "Utah Department of Transportation",
    "dataPortalUrl": "https://data-uplan.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 36.99,
      "latMax": 42.0,
      "lonMin": -114.05,
      "lonMax": -109.04
    },
    "dataDir": "UtahDOT"
  },
  "columnMapping": {
    "_description": "Maps Utah UDOT Crash_Locations MapServer fields to CRASH LENS field codes",
    "_note": "Data from UDOT Crash_Locations MapServer (2017-present, nightly refresh). Spatial Reference: 26912 (NAD83 UTM Zone 12N). Three data tables: Crashes, Vehicle, People. Uses Numetric for querying. Exact ArcGIS field names require FeatureServer metadata query.",
    "ID": "_LIKELY_CRASH_ID",
    "DATE": "_TBD_CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_DERIVED_FROM_GEOMETRY",
    "LON": "_DERIVED_FROM_GEOMETRY",
    "SEVERITY": "_TBD_SEVERITY",
    "JURISDICTION": "_TBD_COUNTY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN"
  },
  "derivedFields": {
    "_description": "Fields computed from raw data during Stage 1 (CONVERT)",
    "_data_note": "UDOT uses Numetric 'rollups' for crash data querying. Three data tables (Crashes, Vehicle, People) joined by Crash ID + Vehicle Number + Person ID. Exact field names TBD from MapServer metadata.",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD",
      "_note": "Utah severity field and KABCO mapping TBD from MapServer metadata"
    },
    "YEAR": {
      "method": "extract_year",
      "source": "_TBD_CRASH_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": ["_TBD_ROAD1", "_TBD_ROAD2"],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Utah road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Utah collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 883,
    "A": 94,
    "B": 21,
    "C": 11,
    "O": 1,
    "_source": "FHWA-SA-25-021 (Oct 2025) crash costs in 2024 dollars"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "UDOT GIS Portal",
    "url": "https://data-uplan.opendata.arcgis.com",
    "apiUrl": "https://maps.udot.utah.gov/central/rest/services/TrafficAndSafety/Crash_Locations/MapServer",
    "_safetyIndex": "https://maps.udot.utah.gov/arcgis/rest/services/Safety_SafetyIndex/MapServer",
    "fileFormat": "GeoJSON/CSV (ArcGIS MapServer)",
    "dataDictionary": "UDOT Crash Data Fields: https://support.numetric.com/en/articles/4730297-udot-crash-data-fields-by-data-table, Codes: https://support.numetric.com/numetric-roads/udot-roads-documentation/crash-data-fields-codes",
    "_dataRange": "2017-present, refreshed nightly",
    "_contacts": "Jeff Lewis (jefflewis@utah.gov) for data, Jonathan Harman (jharman@utah.gov) for maps",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
