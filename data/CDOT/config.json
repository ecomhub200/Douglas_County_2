    "PROCESSING_STATUS": "Processing Status",
    "LAST_UPDATED": "Last Updated"
  },

  "derivedFields": {
    "_description": "Fields that don't exist in Colorado data and must be computed from other columns",

    "SEVERITY": {
      "method": "fromInjuryCounts",
      "description": "Colorado has no single severity column. Derive from highest injury level: if Injury 04 > 0 → K, elif Injury 03 > 0 → A, elif Injury 02 > 0 → B, elif Injury 01 > 0 → C, else → O",
      "sources": ["Injury 04", "Injury 03", "Injury 02", "Injury 01", "Injury 00"]
    },

    "YEAR": {
      "method": "fromDate",
      "description": "Extract year from Crash Date (format: M/D/YYYY)",
      "source": "Crash Date",
      "dateFormat": "M/D/YYYY"
    },

    "PED": {
      "method": "fromNonMotoristType",
      "description": "Check if any TU NM Type contains 'Pedestrian'",
      "sources": ["TU-1 NM Type", "TU-2 NM Type"],
      "matchValues": ["Pedestrian"]
    },

    "BIKE": {
      "method": "fromNonMotoristType",
      "description": "Check if any TU NM Type contains 'Bicycle'",
      "sources": ["TU-1 NM Type", "TU-2 NM Type"],
      "matchValues": ["Bicycle", "Bicycle/Motorized Bicycle"]
    },

    "ALCOHOL": {
      "method": "fromSuspectedFlags",
      "description": "Check if any TU has alcohol suspected = Yes",
      "sources": ["TU-1 Alcohol Suspected", "TU-2 Alcohol Suspected"],
      "positiveValues": ["Yes - SFST", "Yes - BAC", "Yes - Both", "Yes - Observation"]
    },

    "SPEED": {
      "method": "fromDriverAction",
      "description": "Check if driver action indicates speeding",
      "sources": ["TU-1 Driver Action", "TU-2 Driver Action"],
      "matchValues": ["Too Fast for Conditions", "Exceeded Speed Limit"]
    },

    "HITRUN": {
      "method": "fromHitAndRun",
      "description": "Check if any TU hit and run = TRUE",
      "sources": ["TU-1 Hit And Run", "TU-2 Hit And Run"],
      "positiveValues": ["TRUE", "true", "True"]
    },

    "MOTORCYCLE": {
      "method": "fromVehicleType",
      "description": "Check if any TU Type is motorcycle",
      "sources": ["TU-1 Type", "TU-2 Type"],
      "matchValues": ["Motorcycle"]
    },

    "ROUTE": {
      "method": "buildRouteName",
      "description": "Construct route name from System Code + Rd_Number + Location 1",
      "sources": ["System Code", "Rd_Number", "Location 1"]
    },

    "NODE": {
      "method": "buildNodeId",
      "description": "Construct intersection ID from Location 1 + Location 2 when Road Description indicates intersection",
      "sources": ["Location 1", "Location 2", "Road Description"]
    },

    "COLLISION": {
      "method": "mapCrashType",
      "description": "Map Colorado Crash Type / MHE to standardized collision categories",
      "source": "Crash Type",
      "fallback": "MHE"
    },

    "INTERSECTION_TYPE": {
      "method": "mapRoadDescription",
      "description": "Map Road Description to intersection type categories",
      "source": "Road Description"
    },

    "NIGHT": {
      "method": "fromLighting",
      "description": "Derive nighttime flag from Lighting Conditions",
      "source": "Lighting Conditions",
      "matchValues": ["Dark – Lighted", "Dark – Unlighted", "Dark - Lighted", "Dark - Unlighted"]
    },

    "DISTRACTED": {
      "method": "fromDriverAction",
      "description": "Check if driver action or human factor indicates distraction",
      "sources": ["TU-1 Driver Action", "TU-2 Driver Action", "TU-1 Human Contributing Factor", "TU-2 Human Contributing Factor"],
      "matchValues": ["Distracted", "Cell Phone", "Inattention", "Distracted - Cell Phone/Electronic Device", "Distracted - Other", "Inattentive/Distracted"]
    },

    "DROWSY": {
      "method": "fromHumanFactor",
      "description": "Check if human contributing factor indicates drowsiness",
      "sources": ["TU-1 Human Contributing Factor", "TU-2 Human Contributing Factor"],
      "matchValues": ["Asleep/Fatigued", "Fatigued/Asleep", "Ill/Asleep/Fatigued"]
    },

    "DRUG": {
      "method": "fromSuspectedFlags",
      "description": "Check marijuana or other drug suspected flags",
      "sources": ["TU-1  Marijuana Suspected", "TU-2 Marijuana Suspected", "TU-1 Other Drugs Suspected ", "TU-2 Other Drugs Suspected "],
      "positiveValues": ["Yes - Observation", "Yes - SFST", "Yes - Both", "Yes - Test Results", "Unknown"]
    },

    "YOUNG": {
      "method": "fromAge",
      "description": "Check if any driver age is 16-20",
      "sources": ["TU-1 Age", "TU-2 Age"],
      "minAge": 16,
      "maxAge": 20
    },

    "SENIOR": {
      "method": "fromAge",
      "description": "Check if any driver age is 65+",
      "sources": ["TU-1 Age", "TU-2 Age"],
      "minAge": 65,
      "maxAge": 999
    },

    "UNRESTRAINED": {
      "method": "fromRestraintUse",
      "description": "Check if any driver had improper restraint use",
      "sources": ["TU-1 Safety restraint Use", "TU-2 Safety restraint Use"],
      "matchValues": ["Not Used", "Improperly Used"]
    }
  },

