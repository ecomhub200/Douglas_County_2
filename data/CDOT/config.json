    "SURFACE": "Road Condition",
    "LIGHT": "Lighting Conditions",
    "WEATHER": "Weather Condition",
    "WEATHER2": "Weather Condition 2",
    "LANE_POSITION": "Lane Position",
    "TU1_DIRECTION": "TU-1 Direction",
    "TU1_MOVEMENT": "TU-1 Movement",
    "TU1_TYPE": "TU-1 Type",
    "TU1_SPEED_LIMIT": "TU-1 Speed Limit",
    "TU1_ESTIMATED_SPEED": "TU-1 Estimated Speed",
    "TU1_DRIVER_ACTION": "TU-1 Driver Action",
