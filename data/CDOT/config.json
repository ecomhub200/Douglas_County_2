    "filterProfiles": {
      "countyOnly": {
        "name": "County/City Roads Only",
        "description": "Only locally-maintained roads (County Roads + City Streets)",
        "systemValues": ["City Street", "County Road"],
        "excludeRoutePatterns": []
      },
      "countyPlusState": {
        "name": "All Roads (No Interstate)",
        "description": "Local roads plus CDOT state highways, excluding interstates",
        "systemValues": ["City Street", "County Road", "State Highway", "Frontage Road"],
        "excludeRoutePatterns": ["^I-\\d+"]
      },
      "allRoads": {
        "name": "All Roads (Including Interstate)",
        "description": "All road types including interstates",
        "systemValues": ["City Street", "County Road", "State Highway", "Interstate Highway", "Frontage Road"],
        "excludeRoutePatterns": []
      }
    }
  },

