  "columnMapping": {
    "_description": "Maps Colorado CDOT CSV column names to internal field codes used by CRASH LENS",
    "_note": "Colorado does NOT have a single severity column - severity must be DERIVED from Injury 00-04 counts",

    "ID": "CUID",
    "DATE": "Crash Date",
    "TIME": "Crash Time",
    "ROAD_SYSTEM": "System Code",
    "ROUTE_NUMBER": "Rd_Number",
    "ROUTE_SECTION": "Rd_Section",
    "CROSS_STREET": "City_Street",
    "AGENCY": "Agency Id",
    "CITY": "City",
    "JURISDICTION": "County",
    "LAT": "Latitude",
    "LON": "Longitude",
    "LOCATION1": "Location 1",
    "LINK": "Link",
    "LOCATION2": "Location 2",
    "LOCATION_TYPE": "Location",
    "ROAD_DESC": "Road Description",
    "FIRST_HE": "First HE",
    "SECOND_HE": "Second HE",
    "THIRD_HE": "Third HE",
    "FOURTH_HE": "Fourth HE",
    "MHE": "MHE",
    "CRASH_TYPE": "Crash Type",
    "APPROACH_OVERTAKING": "Approach Overtaking Turn",
    "WILD_ANIMAL": "Wild Animal",
    "KILLED": "Number Killed",
    "INJURED": "Number Injured",
    "INJURY_O": "Injury 00",
    "INJURY_C": "Injury 01",
    "INJURY_B": "Injury 02",
    "INJURY_A": "Injury 03",
    "INJURY_K": "Injury 04",
