{
  "state": {
    "name": "Alaska",
    "abbreviation": "AK",
    "fips": "02",
    "dotName": "AKDOT&PF",
    "dotFullName": "Alaska Department of Transportation and Public Facilities",
    "dataPortalUrl": "https://data-soa-akdot.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 51.21,
      "latMax": 71.39,
      "lonMin": -179.15,
      "lonMax": -129.98
    },
    "dataDir": "AlaskaDOT"
  },
  "columnMapping": {
    "_description": "Maps Alaska DOT&PF CrashData FeatureServer fields to CRASH LENS field codes",
    "_note": "Fields from CrashData_test FeatureServer (may be test/dev endpoint). CrashData_Details is a Table (non-spatial, no geometry). Max Record Count: 2,000. Additional fields likely available in production service.",
    "ID": "DOCUMENT_NBR",
    "DATE": "_TBD_CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_TBD_LATITUDE",
    "LON": "_TBD_LONGITUDE",
    "SEVERITY": "CRASH_SEVERITY",
    "JURISDICTION": "_TBD_BOROUGH_OR_AREA",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "MOST_HARMFUL_CRASH_EVENT_CD",
    "FIRST_EVENT": "FIRST_CRASH_EVENT_CD",
    "SECOND_EVENT": "SECOND_CRASH_EVENT_CD",
    "THIRD_EVENT": "THIRD_CRASH_EVENT_CD",
    "FOURTH_EVENT": "FOURTH_CRASH_EVENT_CD",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN",
    "YEAR": "CRASH_YEAR",
    "DIRECTION": "DIRECTION_OF_TRAVEL_CD",
    "IMPACT_AREA": "INITIAL_VEH_IMPACT_AREA_CD"
  },
  "derivedFields": {
    "_description": "Fields computed from raw data during Stage 1 (CONVERT)",
    "_data_warning": "CrashData_test appears to be a development/test service. Production endpoint may differ. Alaska uses boroughs instead of counties.",
    "SEVERITY": {
      "method": "coded_abc",
      "source": "CRASH_SEVERITY",
      "_note": "Alaska CRASH_SEVERITY uses single-char codes: A=Severe Injury, B=Visible Injury, C=Nonvisible Injury. Fatal/PDO codes TBD. May not include K or O directly."
    },
    "YEAR": {
      "method": "direct",
      "source": "CRASH_YEAR"
    },
    "NODE": {
      "method": "not_confirmed",
      "sources": ["_TBD_ROAD1", "_TBD_ROAD2"],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Alaska road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Alaska collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 883,
    "A": 94,
    "B": 21,
    "C": 11,
    "O": 1,
    "_source": "FHWA-SA-25-021 (Oct 2025) crash costs in 2024 dollars"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "AKDOT&PF GIS Portal",
    "url": "https://data-soa-akdot.opendata.arcgis.com",
    "apiUrl": "https://services.arcgis.com/p5v98VHDX9Atv3l7/ArcGIS/rest/services/CrashData_test/FeatureServer",
    "_apiUrlNote": "This appears to be a test/development service. Production endpoint TBD. Layer 1 = CrashData_Details (Table, non-spatial).",
    "fileFormat": "GeoJSON/CSV (ArcGIS)",
    "dataDictionary": "See data-soa-akdot.opendata.arcgis.com and egis-akdot.hub.arcgis.com",
    "_alternatePortal": "https://egis-akdot.hub.arcgis.com/",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
