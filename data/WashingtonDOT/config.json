{
  "state": {
    "name": "Washington",
    "abbreviation": "WA",
    "fips": "53",
    "dotName": "WSDOT",
    "dotFullName": "Washington State Department of Transportation",
    "dataPortalUrl": "https://geo.wa.gov",
    "coordinateBounds": {
      "latMin": 45.54,
      "latMax": 49.0,
      "lonMin": -124.85,
      "lonMax": -116.92
    },
    "dataDir": "WashingtonDOT"
  },
  "columnMapping": {
    "_description": "Maps WSDOT Crash Data Portal fields to CRASH LENS field codes",
    "_note": "Fields from WSDOT NHFP Crash Data Dictionary. Source: Police Traffic Collision Reports (PTCR). Updated weekly (~30-day lag). Coordinates in NAD_1983_HARN_StatePlane_Washington_South_FIPS_4602_Feet.",
    "ID": "CASE_NBR",
    "DATE": "COLLISION_DATE",
    "TIME": "_DERIVED_FROM_COLLISION_DATE",
    "LAT": "_DERIVED_FROM_GEOMETRY",
    "LON": "_DERIVED_FROM_GEOMETRY",
    "SEVERITY": "_TBD_MOST_SEV_INJ",
    "JURISDICTION": "_TBD_COUNTY",
    "CITY": "_TBD_CITY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN",
    "PED_COUNT": "_TBD_PEDESTRIANS_COUNT",
    "BIKE_COUNT": "_TBD_PEDALCYCLISTS_COUNT",
    "VEHICLE_COUNT": "_TBD_VEHICLES_COUNT"
  },
  "derivedFields": {
    "_description": "Fields computed from raw data during Stage 1 (CONVERT)",
    "_data_note": "WSDOT crash data served via dashboard portal, not a direct public FeatureServer. Exact ArcGIS field names TBD from FeatureServer metadata. Standard crash data requests require WSDOT personnel/consultant authorization; public users use Public Disclosure Request Center.",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD_MOST_SEV_INJ",
      "_note": "Washington severity field and KABCO mapping TBD. Killed/serious injury counts available."
    },
    "YEAR": {
      "method": "extract_year",
      "source": "COLLISION_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": ["_TBD_ROAD1", "_TBD_ROAD2"],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Washington road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Washington collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 462,
    "A": 62,
    "B": 12,
    "C": 5,
    "O": 1,
    "_source": "FHWA/HSM Standard"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "WSDOT GIS Portal",
    "url": "https://geo.wa.gov",
    "apiUrl": "https://geo.wa.gov/datasets/WSDOT::wsdot-crash-data-portal",
    "_interactivePortal": "https://remoteapps.wsdot.wa.gov/highwaysafety/collision/data/portal/public/",
    "fileFormat": "GeoJSON/CSV (ArcGIS)",
    "dataDictionary": "WSDOT Crash Data Dictionary: https://wsdot.wa.gov/sites/default/files/2022-01/NHFP-crash-data-dictionary.pdf",
    "_accessNote": "Dashboard-based access. Standard data requests for WSDOT personnel/consultants; public users use Public Disclosure Request Center.",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
