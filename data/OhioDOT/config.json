{
  "state": {
    "name": "Ohio",
    "abbreviation": "OH",
    "fips": "39",
    "dotName": "ODOT",
    "dotFullName": "Ohio Department of Transportation",
    "dataPortalUrl": "https://gis.dot.state.oh.us",
    "coordinateBounds": {
      "latMin": 38.4,
      "latMax": 41.98,
      "lonMin": -84.82,
      "lonMax": -80.52
    },
    "dataDir": "OhioDOT"
  },
  "columnMapping": {
    "_description": "Maps Ohio DOT TIMS crash data fields to CRASH LENS field codes",
    "_note": "Column names from ODOT Crash Data Dictionary. ODOT_NUM is primary key. Severity is 3-tier (1=Fatal, 2=Injury, 3=PDO).",
    "ID": "ODOT_NUM",
    "DATE": "CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_TBD_LATITUDE",
    "LON": "_TBD_LONGITUDE",
    "SEVERITY": "CRASH_SEVERITY",
    "JURISDICTION": "_TBD_COUNTY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_CRASH_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN",
    "FUNCTIONAL_CLASS": "_TBD_FUNC_CLASS"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_coded",
      "source": "CRASH_SEVERITY",
      "_note": "Ohio uses 3-tier severity: 1=Fatal(K), 2=Injury(B conservative), 3=PDO(O). For full KABCO, join with person-level data.",
      "mapping": {
        "1": "K",
        "2": "B",
        "3": "O"
      }
    },
    "YEAR": {
      "method": "extract_year",
      "source": "CRASH_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Ohio road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Ohio collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 883,
    "A": 94,
    "B": 21,
    "C": 11,
    "O": 1,
    "_source": "FHWA-SA-25-021 (Oct 2025) crash costs in 2024 dollars"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "ODOT GIS Portal",
    "url": "https://gis.dot.state.oh.us",
    "apiUrl": "https://gis.dot.state.oh.us/arcgis/rest/services/TIMS/CrashData/FeatureServer/0",
    "fileFormat": "GeoJSON/CSV (ArcGIS)",
    "dataDictionary": "https://www.dot.state.oh.us/Divisions/Planning/LocalPrograms/LTAP/Documents/Crash_Data_Dictionary.pdf",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
