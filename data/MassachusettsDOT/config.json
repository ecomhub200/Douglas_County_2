{
  "state": {
    "name": "Massachusetts",
    "abbreviation": "MA",
    "fips": "25",
    "dotName": "MassDOT",
    "dotFullName": "Massachusetts Department of Transportation",
    "dataPortalUrl": "https://massdot-impact-crashes-vhb.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 41.24,
      "latMax": 42.89,
      "lonMin": -73.51,
      "lonMax": -69.93
    },
    "dataDir": "MassachusettsDOT"
  },
  "columnMapping": {
    "_description": "Maps MassDOT IMPACT crash data fields to CRASH LENS field codes",
    "_note": "Column names from MassDOT IMPACT MASSDOT_ODP_OPEN FeatureServer. Year-specific services (2019-2024). MaxRecordCount=1000. WKID 26986 (NAD83/Mass Mainland). Uses city/town, not county.",
    "ID": "CRASH_NUMB",
    "DATE": "CRASH_DATETIME",
    "DATE_TEXT": "CRASH_DATE_TEXT",
    "TIME": "CRASH_TIME_2",
    "HOUR": "CRASH_HOUR",
    "LAT": "_DERIVED_FROM_GEOMETRY",
    "LON": "_DERIVED_FROM_GEOMETRY",
    "SEVERITY": "CRASH_SEVERITY_DESCR",
    "MAX_INJURY": "MAX_INJR_SVRTY_CL",
    "JURISDICTION": "CITY_TOWN_NAME",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN",
    "CRASH_STATUS": "CRASH_STATUS",
    "POLICE_AGENCY": "POLC_AGNCY_TYPE_DESCR",
    "NUM_VEHICLES": "NUMB_VEHC",
    "FATAL_INJURIES": "NUMB_FATAL_INJR",
    "NONFATAL_INJURIES": "NUMB_NONFATAL_INJR"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct",
      "source": "CRASH_SEVERITY_DESCR",
      "_note": "MassDOT provides CRASH_SEVERITY_DESCR as text. Also MAX_INJR_SVRTY_CL for max injury severity class. Map text values to KABCO."
    },
    "YEAR": {
      "method": "extract_year",
      "source": "CRASH_DATETIME"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Massachusetts road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road"
        ],
        "label": "County Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      },
      "cityOnly": {
        "include": [
          "Local Road"
        ],
        "label": "City Roads Only"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Massachusetts collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 883,
    "A": 94,
    "B": 21,
    "C": 11,
    "O": 1,
    "_source": "FHWA-SA-25-021 (Oct 2025) crash costs in 2024 dollars"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "MassDOT GIS Portal",
    "url": "https://massdot-impact-crashes-vhb.opendata.arcgis.com",
    "apiUrl": "https://gis.impact.dot.state.ma.us/arcgis/rest/services/MassDOT/MASSDOT_ODP_OPEN_2024/FeatureServer/0",
    "_apiUrlNote": "Year-specific services: MASSDOT_ODP_OPEN_{2019-2024}. Layer 0=Crash, 1=Vehicle, 2=Person.",
    "fileFormat": "GeoJSON/CSV (ArcGIS)",
    "dataDictionary": "MassDOT IMPACT Crash Data Portal - https://apps.impact.dot.state.ma.us/helpcdp/",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 1000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
