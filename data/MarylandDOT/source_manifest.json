  "api": {
    "endpoint": "https://opendata.maryland.gov/resource/65du-s3qu.json",
    "pagination": {
      "method": "offset",
      "limit_param": "$limit",
      "offset_param": "$offset",
      "max_per_request": 50000
    },
    "filtering": {
      "county_field": "county_desc",
      "county_code_field": "county_no",
      "date_field": "acc_date",
      "example_query": "$where=county_desc='Montgomery' AND acc_date>='2023-01-01T00:00:00.000'"
    }
  },

  "related_datasets": {
