{
  "_description": "Maryland ACRS crash data registry via Socrata SODA API. Dataset includes all approved crash reports statewide.",
  "_note": "Maryland has 23 counties + Baltimore City (independent city). Filter using county_desc or county_no in SoQL queries.",
  "_updated": "2026-02-15",

  "source": {
    "name": "Maryland Open Data Portal (Socrata)",
    "base_url": "https://opendata.maryland.gov",
    "resource_id": "65du-s3qu",
    "api_url": "https://opendata.maryland.gov/resource/65du-s3qu.json",
    "csv_url": "https://opendata.maryland.gov/api/views/65du-s3qu/rows.csv?accessType=DOWNLOAD",
    "file_format": "JSON/CSV (Socrata SODA API)"
  },

  "jurisdiction_filters": {
