{
  "state": {
    "name": "Illinois",
    "abbreviation": "IL",
    "fips": "17",
    "dotName": "IDOT",
    "dotFullName": "Illinois Department of Transportation",
    "dataPortalUrl": "https://gis-idot.opendata.arcgis.com",
    "coordinateBounds": {
      "latMin": 36.97,
      "latMax": 42.51,
      "lonMin": -91.51,
      "lonMax": -87.5
    },
    "dataDir": "IllinoisDOT"
  },
  "columnMapping": {
    "_description": "Maps Illinois IDOT crash data fields to CRASH LENS field codes",
    "_note": "Yearly ArcGIS layers from 2014-2024 (e.g., 'Crashes - 2024'). FeatureServer URLs are dynamically assigned per dataset page. Download CSV to inspect exact field names. Data dictionary: IL SR 1050 Traffic Crash Report. Crash types: Type A (PDO), Type B (injury/tow).",
    "ID": "_TBD_CRASH_ID",
    "DATE": "_TBD_CRASH_DATE",
    "TIME": "_TBD_CRASH_TIME",
    "LAT": "_TBD_LATITUDE",
    "LON": "_TBD_LONGITUDE",
    "SEVERITY": "_TBD_SEVERITY",
    "JURISDICTION": "_TBD_COUNTY",
    "ROUTE": "_TBD_ROAD_NAME",
    "COLLISION": "_TBD_COLLISION_TYPE",
    "WEATHER": "_TBD_WEATHER",
    "LIGHT": "_TBD_LIGHTING",
    "SURFACE_CONDITION": "_TBD_SURFACE",
    "JUNCTION": "_TBD_JUNCTION_TYPE",
    "HITRUN": "_TBD_HIT_AND_RUN"
  },
  "derivedFields": {
    "_description": "Fields that must be computed from raw data during Stage 1 (CONVERT)",
    "SEVERITY": {
      "method": "direct_or_derived",
      "source": "_TBD",
      "_note": "Update with Illinois-specific severity derivation method"
    },
    "YEAR": {
      "method": "extract_year",
      "source": "_TBD_CRASH_DATE"
    },
    "NODE": {
      "method": "concatenate",
      "sources": [
        "_TBD_ROAD1",
        "_TBD_ROAD2"
      ],
      "separator": " & "
    }
  },
  "roadSystems": {
    "_description": "Illinois road classification for road-type filtering",
    "values": {
      "Interstate": {
        "classification": "state_maintained",
        "label": "Interstate"
      },
      "US Route": {
        "classification": "state_maintained",
        "label": "US Route"
      },
      "State Route": {
        "classification": "state_maintained",
        "label": "State Route"
      },
      "County Road": {
        "classification": "local",
        "label": "County Road"
      },
      "Local Road": {
        "classification": "local",
        "label": "Local Road"
      }
    },
    "filterProfiles": {
      "countyOnly": {
        "include": [
          "County Road",
          "Local Road"
        ],
        "label": "County & Local Roads Only"
      },
      "countyPlusState": {
        "include": [
          "County Road",
          "Local Road",
          "State Route",
          "US Route"
        ],
        "label": "County + State Routes"
      },
      "allRoads": {
        "include": [
          "Interstate",
          "US Route",
          "State Route",
          "County Road",
          "Local Road"
        ],
        "label": "All Roads"
      }
    }
  },
  "crashTypeMapping": {
    "_description": "Maps Illinois collision type values to CRASH LENS standard",
    "_note": "Update with actual state values from data dictionary"
  },
  "epdoWeights": {
    "K": 462,
    "A": 62,
    "B": 12,
    "C": 5,
    "O": 1,
    "_source": "FHWA/HSM Standard"
  },
  "validValues": {
    "severity": {
      "K": "Fatal",
      "A": "Suspected Serious Injury",
      "B": "Suspected Minor Injury",
      "C": "Possible Injury",
      "O": "Property Damage Only"
    }
  },
  "dataSource": {
    "name": "IDOT GIS Portal",
    "url": "https://gis-idot.opendata.arcgis.com",
    "apiUrl": "https://gis-idot.opendata.arcgis.com/datasets/crashes/FeatureServer/0",
    "_apiNote": "Yearly layers: 'Crashes - 2024', 'Crashes - 2023', etc. (2014-2024). FeatureServer URL varies per year/dataset. CSV/KML/GeoJSON/Shapefile downloads available.",
    "fileFormat": "CSV, KML, GeoJSON, Shapefile (ArcGIS)",
    "dataDictionary": "IL Dictionary of Data Elements - Traffic Crash Report (SR 1050): https://idot.illinois.gov/content/dam/soi/en/web/idot/documents/transportation-system/reports/safety/itrcc/il-data-dictionary-march-2011.pdf",
    "pagination": {
      "method": "offset",
      "maxPerRequest": 2000,
      "paramOffset": "resultOffset",
      "paramCount": "resultRecordCount"
    }
  }
}
