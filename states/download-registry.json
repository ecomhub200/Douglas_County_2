{
  "_comment": "State download registry. Maps each state to its download script, data directory, and invocation pattern. Used by the universal download-state-crash-data.yml workflow.",
  "_tiers": {
    "1": "Scope-aware (jurisdiction/region/mpo/statewide), triggers pipeline.yml — Virginia, Colorado",
    "2": "Jurisdiction-specific with dropdown, R2 upload, no pipeline trigger — Maryland",
    "3": "Generic pattern: --data-dir, --jurisdiction, --years, --force, --gzip, R2 upload"
  },
  "_fieldReference": {
    "scriptArgs": "Base arguments always passed to the download script",
    "statewideFlagArgs": "Extra flags appended for statewide download mode",
    "forceFlag": "CLI flag to force re-download (skip cache)",
    "statewideOutputPattern": "Expected path to statewide CSV after download; {state} and {dotDir} are replaced",
    "statewideOutputGzPattern": "Expected path to gzipped statewide CSV (checked if plain CSV not found)",
    "needsStandardization": "If true, run process_crash_data.py to convert to standard column format",
    "needsMerge": "If true, check for multiple raw CSVs and merge before conversion"
  },

  "virginia": {
    "displayName": "Virginia",
    "dotDir": "data",
    "script": "download_crash_data.py",
    "tier": 1,
    "requiresPlaywright": false,
    "defaultJurisdiction": "henrico",
    "defaultRegion": "richmond",
    "defaultMpo": "rvampo",
    "scriptArgs": "--output-dir data --jurisdiction {defaultJurisdiction}",
    "statewideFlagArgs": "--save-statewide",
    "forceFlag": "--force-download",
    "statewideOutputPattern": "{dotDir}/virginia_statewide_all_roads.csv",
    "statewideOutputGzPattern": "{dotDir}/virginia_statewide_all_roads.csv.gz",
    "needsStandardization": false,
    "needsMerge": false,
    "pipelineWorkflow": "pipeline.yml",
    "r2Prefix": "virginia",
    "jurisdictionOutputPattern": "data/{jurisdiction}_all_roads.csv"
  },

