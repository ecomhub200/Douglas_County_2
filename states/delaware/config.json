      },
      "State Route": {
        "category": "state",
        "isStateDOT": true,
        "isInterstate": false,
        "displayName": "State Route",
        "standardizedSystem": "Primary"
      },
      "County Road": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "County Road",
