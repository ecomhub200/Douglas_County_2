    "ROAD_DESC": null,
    "ROUTE": null,
    "ROAD_SYSTEM": null,
    "X": "longitude",
    "Y": "latitude",
    "JURISDICTION": "county_name",
    "PED": "pedestrian_involved",
    "BIKE": "bicycled_involved",
