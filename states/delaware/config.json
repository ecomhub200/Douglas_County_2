  "derivedFields": {
    "_description": "Delaware provides 3-tier crash-level severity (Fatal/Injury/PDO). No individual injury counts (A/B/C breakdown unavailable).",
    "SEVERITY": {
      "method": "crash_classification",
      "column": "crash_classification_description",
      "mapping": {
        "Fatality Crash": "K",
        "Personal Injury Crash": "B",
        "Property Damage Only": "O",
        "Non-Reportable": "O"
      }
    },
    "ROUTE": {
      "method": "reverse_geocode",
      "note": "Delaware crash data has NO road name field. Requires reverse geocoding from lat/lon or manual enrichment."
    }
  },

  "missingFields": {
    "_description": "Fields NOT available in Delaware public crash data",
    "unavailable": [
      "Road/Route Name (RTE Name)",
      "Road System Classification (SYSTEM)",
      "Intersection Node",
      "Milepost",
      "Traffic Control Type",
      "Functional Class",
      "Area Type",
      "Facility Type",
      "Road Ownership",
      "Road Alignment",
      "Speed Involved flag",
      "Hit-and-Run flag",
      "Distracted Driving flag",
      "Drowsy Driving flag",
      "Driver Age (Young/Senior flags)",
      "First Harmful Event",
      "Vehicle Count"
    ],
    "enrichmentOptions": {
      "reverseGeocoding": "Use Nominatim/OSM to derive road names from lat/lon coordinates",
      "roadNetworkOverlay": "Snap crash points to DelDOT road network shapefile for route names and functional class"
    }
  },

  "roadSystems": {
