{
  "state": {
    "name": "Colorado",
    "abbreviation": "CO",
    "fips": "08",
    "dotName": "CDOT",
    "dotFullName": "Colorado Department of Transportation",
    "dataSystemName": "CDOT OnBase Portal",
    "dataPortalUrl": "https://www.codot.gov/safety/traffic-safety/crash-data",
    "coordinateBounds": {
      "latMin": 36.9,
      "latMax": 41.1,
      "lonMin": -109.1,
      "lonMax": -101.9
    }
  },

  "columnMapping": {
    "_description": "Maps Colorado CDOT CSV column names to internal field codes",

    "ID": "CUID",
    "DATE": "Crash Date",
    "TIME": "Crash Time",
    "SEVERITY": null,
    "K": "Injury 04",
    "A": "Injury 03",
    "B": "Injury 02",
    "C": "Injury 01",
    "O": "Injury 00",
    "COLLISION": "Crash Type",
    "WEATHER": "Weather Condition",
    "LIGHT": "Lighting Conditions",
    "SURFACE": "Road Condition",
    "ALIGNMENT": "Road Contour Curves",
    "ROAD_DESC": "Road Description",
    "ROUTE": "Rd_Number",
    "ROAD_SYSTEM": "System Code",
    "X": "Longitude",
    "Y": "Latitude",
    "JURISDICTION": "County",
    "AGENCY": "Agency Id",
    "FIRST_HARMFUL": "First HE",
    "FIRST_HARMFUL_LOC": "Location"
  },

  "derivedFields": {
    "_description": "Colorado severity is derived from injury count columns (Injury 04..00 = K..O)",
    "SEVERITY": {
      "method": "injury_hierarchy",
      "columns": ["Injury 04", "Injury 03", "Injury 02", "Injury 01", "Injury 00"],
      "labels": ["K", "A", "B", "C", "O"]
    }
  },

  "roadSystems": {
    "values": {
      "City Street": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "City Street",
        "standardizedSystem": "NonVDOT secondary"
      },
      "County Road": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "County Road",
        "standardizedSystem": "NonVDOT secondary"
      },
      "State Highway": {
        "category": "state",
        "isStateDOT": true,
        "isInterstate": false,
        "displayName": "State Highway",
        "standardizedSystem": "Primary"
      },
      "Interstate Highway": {
        "category": "interstate",
        "isStateDOT": true,
        "isInterstate": true,
        "displayName": "Interstate Highway",
        "standardizedSystem": "Interstate"
      },
      "Frontage Road": {
        "category": "state",
        "isStateDOT": true,
        "isInterstate": false,
        "displayName": "Frontage Road",
        "standardizedSystem": "Secondary"
      },
      "Non Crash": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "Non Crash",
        "standardizedSystem": "NonVDOT secondary"
      }
    },

    "splitConfig": {
      "_description": "Config-driven split logic for stage_split in process_crash_data.py",
      "countyRoads": {
        "method": "agency_id",
        "column": "_co_agency_id",
        "agencyMap": {
          "douglas": ["DSO"],
          "arapahoe": ["ASO"],
          "jefferson": ["JSO"],
          "elpaso": ["EPSO"],
          "denver": ["DPD"],
          "adams": ["ACSO"]
        }
      },
      "cityRoads": {
        "method": "column_value",
        "column": "_co_system_code",
        "includeValues": ["City Street"]
      },
      "interstateExclusion": {
        "method": "column_value",
        "column": "_co_system_code",
        "excludeValues": ["Interstate Highway"]
      }
    },

    "filterProfiles": {
      "countyOnly": {
        "name": "County Roads Only",
        "description": "County-maintained roads only",
        "systemValues": ["NonVDOT secondary"]
      },
      "cityOnly": {
        "name": "City Roads Only",
        "description": "City street roads only",
        "systemCodeValues": ["City Street"]
      },
      "countyPlusVDOT": {
        "name": "All Roads (No Interstate)",
        "description": "Local roads plus state highways, excluding interstates",
        "systemValues": ["NonVDOT secondary", "Primary", "Secondary"]
      },
      "allRoads": {
        "name": "All Roads (Including Interstate)",
        "description": "All road types including interstates",
        "systemValues": ["NonVDOT secondary", "Primary", "Secondary", "Interstate"]
      }
    }
  },

  "epdoWeights": {
    "_source": "HSM Standard (2010) - CDOT uses AASHTO/FHWA standard weights",
    "K": 883,
    "A": 94,
    "B": 21,
    "C": 11,
    "O": 1
  },

