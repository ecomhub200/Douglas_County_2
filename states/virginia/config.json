        "displayName": "Non-DOT Primary"
      },
      "Non-DOT": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "Non-DOT"
      },
      "DOT Primary": {
        "category": "state",
        "isStateDOT": true,
        "isInterstate": false,
        "displayName": "DOT Primary"
      },
      "DOT Secondary": {
        "category": "state",
        "isStateDOT": true,
        "isInterstate": false,
