      "Non-VDOT": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "Non-VDOT"
      },
      "Primary": {
        "category": "state",
        "isStateDOT": true,
        "isInterstate": false,
        "displayName": "VDOT Primary"
      },
      "Secondary": {
        "category": "state",
        "isStateDOT": true,
        "isInterstate": false,
