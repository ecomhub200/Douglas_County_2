  "roadSystems": {
    "values": {
      "NonVDOT secondary": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "NonVDOT Secondary"
      },
      "NONVDOT": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "NonVDOT"
