      "Interstate": {
        "category": "interstate",
        "isStateDOT": true,
        "isInterstate": true,
        "displayName": "Interstate"
      }
    },

    "splitConfig": {
      "_description": "Config-driven split logic for stage_split in process_crash_data.py",
      "countyRoads": {
        "method": "system_column",
        "column": "SYSTEM",
        "includeValues": ["NonVDOT secondary", "NONVDOT", "Non-VDOT"]
      },
      "interstateExclusion": {
        "method": "system_column",
        "column": "SYSTEM",
        "excludeValues": ["Interstate"]
      }
    },

    "filterProfiles": {
      "countyOnly": {
        "name": "County/City Roads Only",
        "description": "Only locally-maintained roads (NonVDOT)",
        "systemValues": ["NonVDOT secondary", "NONVDOT", "Non-VDOT"]
      },
      "countyPlusVDOT": {
        "name": "All Roads (No Interstate)",
        "description": "Local roads plus VDOT primary/secondary, excluding interstates",
        "systemValues": ["NonVDOT secondary", "NONVDOT", "Non-VDOT", "Primary", "Secondary"],
        "excludeRoutePatterns": ["^I-\\d+"]
      },
      "allRoads": {
        "name": "All Roads (Including Interstate)",
        "description": "All road types including interstates",
        "systemValues": ["NonVDOT secondary", "NONVDOT", "Non-VDOT", "Primary", "Secondary", "Interstate"]
      }
    }
  },

