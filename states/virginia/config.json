      "DOT Interstate": {
        "category": "interstate",
        "isStateDOT": true,
        "isInterstate": true,
        "displayName": "DOT Interstate"
      }
    },

    "splitConfig": {
      "_description": "Config-driven split logic. includeValues supports both decoded text AND raw ArcGIS numeric codes.",
      "countyRoads": {
        "method": "ownership",
        "column": "Ownership",
        "columnAliases": ["OWNERSHIP"],
        "includeValues": ["2. County Hwy Agency", "2"]
      },
      "cityRoads": {
        "method": "ownership",
        "column": "Ownership",
        "columnAliases": ["OWNERSHIP"],
        "includeValues": ["3. City or Town Hwy Agency", "3"]
      },
      "interstateExclusion": {
        "method": "functional_class",
        "column": "Functional Class",
        "columnAliases": ["FUN"],
        "excludeValues": ["1-Interstate (A,1)", "INT"]
      }
    },

    "filterProfiles": {
      "countyOnly": {
        "name": "County Roads Only",
        "description": "County-maintained roads only (County Hwy Agency)",
        "systemValues": ["Non-DOT secondary", "Non-DOT primary", "Non-DOT"]
      },
      "cityOnly": {
        "name": "City Roads Only",
        "description": "City/town agency-maintained roads only",
        "ownershipValues": ["3. City or Town Hwy Agency"]
      },
      "countyPlusVDOT": {
        "name": "All Roads (No Interstate)",
        "description": "Local roads plus DOT primary/secondary, excluding interstates",
        "systemValues": ["Non-DOT secondary", "Non-DOT primary", "Non-DOT", "DOT Primary", "DOT Secondary"],
        "excludeRoutePatterns": ["^I-\\d+"]
      },
      "allRoads": {
        "name": "All Roads (Including Interstate)",
        "description": "All road types including interstates",
        "systemValues": ["Non-DOT secondary", "Non-DOT primary", "Non-DOT", "DOT Primary", "DOT Secondary", "DOT Interstate"]
      }
    }
  },

