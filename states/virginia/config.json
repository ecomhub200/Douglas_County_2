  "roadSystems": {
    "values": {
      "Non-DOT secondary": {
        "category": "local",
        "isStateDOT": false,
        "isInterstate": false,
        "displayName": "Non-DOT Secondary"
      },
      "Non-DOT primary": {
        "category": "local",
