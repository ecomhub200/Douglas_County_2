# ==============================================================================
# CRASH LENS - Coolify Environment Variables
# ==============================================================================
# Copy this file or add these variables in Coolify Dashboard:
#   Service > Environment Variables
#
# IMPORTANT: Never commit actual secrets to version control.
# ==============================================================================

# --- Client-Side API Keys (injected into app at container startup) ---

# Mapbox: satellite tiles, geocoding search
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=

# Google Maps: Street View imagery
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# Mapillary: street-level imagery and map features
# Get from: https://www.mapillary.com/developer/api-documentation
MAPILLARY_ACCESS_TOKEN=

# Firebase: authentication and user management
# Get from: https://console.firebase.google.com/ > Project Settings > General
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# --- Brevo Email Notifications (pick ONE mode) ---

# Option A: API Mode (recommended)
# Get from: Brevo > Profile icon (top-right) > SMTP & API > API Keys > Generate
# Key starts with: xkeysib-
BREVO_API_KEY=

# Option B: SMTP Mode (fallback)
# Get from: Brevo Dashboard > SMTP & API > SMTP tab
BREVO_SMTP_LOGIN=
BREVO_SMTP_PASSWORD=

# Sender address (required for either mode)
# Must be a verified sender in Brevo
NOTIFICATION_FROM_EMAIL=notifications@crashlens.aicreatesai.com

# --- Stripe Payment Processing ---

# Stripe API keys (from Stripe Dashboard > Developers > API Keys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook signing secret (from Stripe Dashboard > Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (from Stripe Dashboard > Products > Prices)
# Create 2 products: "CRASH LENS Individual" and "CRASH LENS Team"
# Each with monthly and annual recurring prices
STRIPE_PRICE_INDIVIDUAL_MONTHLY=
STRIPE_PRICE_INDIVIDUAL_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=

# Application URL (used for Stripe success/cancel redirects)
APP_URL=https://crashlens.aicreatesai.com

# Firebase Admin SDK service account JSON (for server-side Firestore updates)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Paste the entire JSON string as a single line
FIREBASE_SERVICE_ACCOUNT=

# --- R2 Worker Proxy (for Traffic Inventory & Data Validator uploads) ---

# R2 Worker URL (Cloudflare Worker that proxies uploads to R2)
# This is injected into client-side api-keys.json (non-secret)
R2_WORKER_URL=https://r2-upload.ecomhub200.workers.dev

# R2 Worker Upload Secret (server-side only — NEVER exposed to frontend)
# This is the X-Upload-Secret header value for the R2 Worker
R2_WORKER_SECRET=

# R2 Public URL for reading files (optional, defaults to https://data.aicreatesai.com)
R2_PUBLIC_URL=https://data.aicreatesai.com

# --- Qdrant Vector Database ---
QDRANT_ENDPOINT=
QDRANT_API_KEY=
