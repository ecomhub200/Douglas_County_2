# ==============================================================================
# CRASH LENS - Coolify Environment Variables
# ==============================================================================
# Copy this file or add these variables in Coolify Dashboard:
#   Service > Environment Variables
#
# IMPORTANT: Never commit actual secrets to version control.
# ==============================================================================

# --- Brevo Email Notifications (pick ONE mode) ---

# Option A: API Mode (recommended)
# Get from: Brevo > Profile icon (top-right) > SMTP & API > API Keys > Generate
# Key starts with: xkeysib-
BREVO_API_KEY=

# Option B: SMTP Mode (fallback)
# Get from: Brevo Dashboard > SMTP & API > SMTP tab
BREVO_SMTP_LOGIN=
BREVO_SMTP_PASSWORD=

# Sender address (required for either mode)
# Must be a verified sender in Brevo
NOTIFICATION_FROM_EMAIL=notifications@crashlens.aicreatesai.com

# --- Qdrant Vector Database ---
QDRANT_ENDPOINT=
QDRANT_API_KEY=
