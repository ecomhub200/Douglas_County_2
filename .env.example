# ==============================================================================
# CRASH LENS - Coolify Environment Variables
# ==============================================================================
# Copy this file or add these variables in Coolify Dashboard:
#   Service > Environment Variables
#
# IMPORTANT: Never commit actual secrets to version control.
# ==============================================================================

# --- Client-Side API Keys (injected into app at container startup) ---

# Mapbox: satellite tiles, geocoding search
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=

# Google Maps: Street View imagery
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# Mapillary: street-level imagery and map features
# Get from: https://www.mapillary.com/developer/api-documentation
MAPILLARY_ACCESS_TOKEN=

# Firebase: authentication and user management
# Get from: https://console.firebase.google.com/ > Project Settings > General
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# --- Brevo Email Notifications (pick ONE mode) ---

# Option A: API Mode (recommended)
# Get from: Brevo > Profile icon (top-right) > SMTP & API > API Keys > Generate
# Key starts with: xkeysib-
BREVO_API_KEY=

# Option B: SMTP Mode (fallback)
# Get from: Brevo Dashboard > SMTP & API > SMTP tab
BREVO_SMTP_LOGIN=
BREVO_SMTP_PASSWORD=

# Sender address (required for either mode)
# Must be a verified sender in Brevo
NOTIFICATION_FROM_EMAIL=notifications@crashlens.aicreatesai.com

# --- Qdrant Vector Database ---
QDRANT_ENDPOINT=
QDRANT_API_KEY=
