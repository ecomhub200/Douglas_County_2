    "defaultMpo": "rvampo",
    "r2Prefix": "virginia",
    "tier": 1,
    "requiresPlaywright": true,
    "needsStandardization": false,
    "needsMerge": false,
    "statewideOutputPattern": "data/virginia_statewide_all_roads.csv",
    "statewideOutputGzPattern": "data/virginia_statewide_all_roads.csv.gz"
  }
}
