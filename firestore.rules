rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: each user can read/write only their own document
    match /users/{userId} {
      // Allow read only if the authenticated user is reading their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow create only for the authenticated user creating their own document
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.plan == 'trial';

      // Allow update only for the authenticated user updating their own document
      allow update: if request.auth != null
                    && request.auth.uid == userId;

      // Never allow delete of user documents from client
      allow delete: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
