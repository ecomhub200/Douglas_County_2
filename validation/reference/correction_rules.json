{
  "metadata": {
    "version": "1.0.0",
    "lastUpdated": "2026-01-26",
    "description": "Auto-correction rules for Virginia crash data validation"
  },

  "confidenceThresholds": {
    "autoApply": 85,
    "suggest": 50,
    "flagOnly": 0,
    "description": {
      "100": "Certain - formatting fixes, no interpretation needed",
      "95-99": "Very High - clear mapping, minimal ambiguity",
      "85-94": "High - confident match, apply with logging",
      "50-84": "Medium - suggest but don't apply automatically",
      "0-49": "Low - flag for manual review only"
    }
  },

