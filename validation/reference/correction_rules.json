  "coordinateCorrections": {
    "outsideVirginia": {
      "check": "coordinates outside Virginia state bounds",
      "action": "flag",
      "confidence": 0,
      "severity": "error",
      "reason": "Coordinate outside Virginia state bounds - likely data entry error"
    },

    "outsideJurisdiction": {
      "check": "coordinates outside stated jurisdiction bbox",
      "action": "flag",
      "confidence": 0,
      "severity": "warning",
      "reason": "Coordinate outside stated jurisdiction bounds - may be boundary crash"
    },

    "nullCoordinatesWithNode": {
      "check": "coordinates null but Node field populated",
      "action": "lookup",
      "source": "node_coordinates_table",
      "confidence": 90,
      "reason": "Can potentially recover coordinates from Node ID lookup"
    },

    "offRoadCoordinate": {
      "check": "coordinate > 50m from nearest road",
      "action": "snap",
      "maxDistance": 50,
      "confidence": 85,
      "reason": "Snap to nearest road within 50m threshold"
    },

    "farFromRoad": {
      "check": "coordinate > 100m from nearest road",
      "action": "flag",
      "confidence": 0,
      "severity": "warning",
      "reason": "Coordinate far from any road - needs manual review"
    },

    "transposedLatLon": {
      "check": "latitude in longitude range or vice versa",
      "action": "swap",
      "confidence": 95,
      "reason": "Lat/Lon appear to be transposed based on Virginia bounds"
    }
  },

  "formatCorrections": {
    "trimWhitespace": {
      "apply": "all_string_fields",
      "pattern": "^\\s+|\\s+$",
      "replacement": "",
      "confidence": 100,
      "reason": "Remove leading/trailing whitespace"
    },

    "removeQuotes": {
      "apply": "all_string_fields",
      "pattern": "^[\"']|[\"']$",
      "replacement": "",
      "confidence": 100,
      "reason": "Remove enclosing quotes"
    },

    "normalizeBoolean": {
      "apply": "boolean_fields",
      "mappings": {
        "Y": "Yes",
        "N": "No",
        "1": "Yes",
        "0": "No",
        "TRUE": "Yes",
        "FALSE": "No",
        "true": "Yes",
        "false": "No",
        "yes": "Yes",
        "no": "No"
      },
      "confidence": 100,
      "reason": "Normalize boolean values to Yes/No"
    },

    "uppercaseSeverity": {
      "apply": ["Crash Severity"],
      "transform": "uppercase",
      "confidence": 100,
      "reason": "Severity should be uppercase K/A/B/C/O"
    },

    "integerInjuryCounts": {
      "apply": ["K_People", "A_People", "B_People", "C_People", "Persons Injured", "Pedestrians Killed", "Pedestrians Injured"],
      "transform": "integer",
      "default": 0,
      "confidence": 100,
      "reason": "Injury counts should be integers, default to 0 if missing"
    }
  },

  "duplicateHandling": {
    "exactDuplicate": {
      "action": "keep_first",
      "confidence": 100,
      "reason": "Exact duplicate rows - keep first occurrence"
    },

    "duplicateDocumentNbr": {
      "action": "keep_first",
      "confidence": 100,
      "reason": "Duplicate Document Number - keep first occurrence, log discrepancy"
    },

    "potentialDuplicate": {
      "criteria": {
        "sameFields": ["Crash Date", "x", "y", "Crash Severity"],
        "tolerances": {
          "x": 0.0001,
          "y": 0.0001
        }
      },
      "action": "flag",
      "confidence": 0,
      "reason": "Potential duplicate - same location/date/severity - needs review"
    }
  },

  "severityConsistency": {
    "fatalWithNoKPeople": {
      "condition": {
        "severity": "K",
        "K_People": 0
      },
      "action": "flag",
      "confidence": 0,
      "severity": "error",
      "reason": "Fatal crash (K) should have K_People > 0"
    },

    "seriousInjuryWithNoAPeople": {
      "condition": {
        "severity": "A",
        "A_People": 0,
        "totalInjured": 0
      },
      "action": "flag",
      "confidence": 0,
      "severity": "warning",
      "reason": "Serious injury crash (A) should have A_People > 0 or injuries recorded"
    }
  }
}
